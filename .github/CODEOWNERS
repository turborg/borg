# borg code owners
#
# Lines later in the file take precedence. The default rule covers everything.
# Add per-area rules below as the team grows and people specialize.
#
# `@turborg/maintainers` is the GitHub team that owns review across the repo.

*                                @turborg/maintainers

# Agent loop + harness (the quality-critical core)
/internal/agent/                 @turborg/maintainers

# Tools the agent runs locally
/internal/tools/                 @turborg/maintainers

# Auth (OAuth PKCE + device grant, token storage)
/internal/auth/                  @turborg/maintainers

# Metered LLM client
/internal/llm/                   @turborg/maintainers

# Evals — the quality signal over time
/internal/eval/                  @turborg/maintainers

# CI / release / security tooling
/.github/                        @turborg/maintainers
/release-please-config.json      @turborg/maintainers
/.release-please-manifest.json   @turborg/maintainers
/.goreleaser.yml                 @turborg/maintainers
/.testcoverage.yml               @turborg/maintainers
/.golangci.yml                   @turborg/maintainers

# Legal / governance
/LICENSE                         @turborg/maintainers
/NOTICE                          @turborg/maintainers
/CLA.md                          @turborg/maintainers
/SECURITY.md                     @turborg/maintainers
